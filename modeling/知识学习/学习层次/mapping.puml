@startuml Mapping

class Mapping{
    + KN-ID: 主键
}

class AnkiKnowledge{
    + KN-ID:主键
}

class AnkiProblem{
    + PR-ID:主键
    + KN-IDs[]
    + PS-ID
}

class AnkiProcess{
    + PS-ID:主键
    + KN-IDs[]
}

class AnkiErrorCase{
    + ER-ID: 主键
    + KN-IDs[]
    + PR-ID
    + PS-ID
}

class Adjacency{
    + KN-IDs[]
    + PR-IDs[]
    + PS-IDs[]
    + ER-IDs[]
}

AnkiKnowledge --> Mapping
AnkiProblem --> Mapping
AnkiProcess --> Mapping
AnkiErrorCase --> Mapping
Mapping --> Adjacency

Adjacency ..> AnkiKnowledge
Adjacency ..> AnkiProblem
Adjacency ..> AnkiProcess
Adjacency ..> AnkiErrorCase

@enduml